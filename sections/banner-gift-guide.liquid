{% comment %}
  ============================================================
  Section: Banner Gift Guide
  Description: Fully customizable Hero banner with nav bar, 
               separate mobile/desktop images, overlay controls,
               and complete color/text settings.
  ============================================================
{% endcomment %}

{%- style -%}
  #bgg-{{ section.id }} {
    /* Base Variables from Settings */
    --bgg-height-desktop: {{ section.settings.height_desktop }}px;
    --bgg-height-mobile: {{ section.settings.height_mobile }}px;
    --bgg-overlay-color: {{ section.settings.overlay_color }};
    --bgg-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    
    /* Colors */
    --bgg-nav-bg: {{ section.settings.nav_bg_color }};
    --bgg-nav-text: {{ section.settings.nav_text_color }};
    --bgg-heading-color: {{ section.settings.heading_color }};
    --bgg-text-color: {{ section.settings.text_color }};
    
    /* Primary Button (Hero) */
    --bgg-btn-bg: {{ section.settings.btn_bg_color }};
    --bgg-btn-text: {{ section.settings.btn_text_color }};
    --bgg-btn-hover-bg: {{ section.settings.btn_hover_bg_color }};
    --bgg-btn-hover-text: {{ section.settings.btn_hover_text_color }};

    /* Secondary Button (Nav) */
    --bgg-nav-btn-bg: {{ section.settings.nav_btn_bg_color }};
    --bgg-nav-btn-text: {{ section.settings.nav_btn_text_color }};
  }

  /* ── Reset & Structure ── */
  .bgg-section *, .bgg-section *::before, .bgg-section *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .bgg-section {
    position: relative;
    width: 100%;
    background-color: var(--bgg-nav-bg);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    overflow: hidden;
  }

  /* ── Nav Bar ── */
  .bgg-nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 60px;
    background: var(--bgg-nav-bg);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    position: relative; z-index: 10;
  }
  .bgg-nav__logo-link { display: flex; align-items: center; text-decoration: none; }
  .bgg-nav__logo-img { max-height: 40px; width: auto; object-fit: contain; }
  .bgg-nav__logo-text { font-family: 'Georgia', serif; font-size: 18px; font-weight: 700; color: var(--bgg-nav-text); text-transform: uppercase; }
  .bgg-nav__tagline { font-size: 13px; color: var(--bgg-nav-text); position: absolute; left: 50%; transform: translateX(-50%); }

  /* ── Buttons ── */
  .bgg-btn {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none;
    padding: 12px 24px; position: relative; overflow: hidden; transition: color 0.35s ease;
    border: 2px solid transparent; cursor: pointer;
  }
  .bgg-btn::before {
    content: ''; position: absolute; inset: 0; transform: translateX(-101%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); z-index: 0;
  }
  .bgg-btn span, .bgg-btn svg { position: relative; z-index: 1; }
  .bgg-btn:hover::before { transform: translateX(0); }
  .bgg-btn__arrow { width: 18px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; transition: transform 0.25s ease; }
  .bgg-btn:hover .bgg-btn__arrow { transform: translateX(4px); }

  /* Specific Button Colors */
  .bgg-btn--nav { background: var(--bgg-nav-btn-bg); color: var(--bgg-nav-btn-text); border-color: var(--bgg-nav-text); }
  .bgg-btn--nav::before { background: var(--bgg-nav-text); }
  .bgg-btn--nav:hover { color: var(--bgg-nav-btn-bg); }

  .bgg-btn--hero { background: var(--bgg-btn-bg); color: var(--bgg-btn-text); border-color: var(--bgg-btn-bg); }
  .bgg-btn--hero::before { background: var(--bgg-btn-hover-bg); }
  .bgg-btn--hero:hover { color: var(--bgg-btn-hover-text); border-color: var(--bgg-btn-hover-bg); }

  /* ── Hero Area ── */
  .bgg-hero {
    position: relative;
    height: var(--bgg-height-desktop);
    display: flex; align-items: flex-end; padding: 40px 32px 60px;
  }
  .bgg-hero__bg-wrap { position: absolute; inset: 0; z-index: 0; }
  .bgg-hero__bg-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .bgg-hero__overlay {
    position: absolute; inset: 0; z-index: 1;
    background-color: var(--bgg-overlay-color);
    opacity: var(--bgg-overlay-opacity);
  }

  /* Content */
  .bgg-hero__content { position: relative; z-index: 2; max-width: 460px; }
  .bgg-hero__heading { font-family: 'Georgia', serif; font-size: clamp(36px, 5vw, 62px); color: var(--bgg-heading-color); margin-bottom: 18px; line-height: 1.1; }
  .bgg-hero__description { font-size: 15px; line-height: 1.6; color: var(--bgg-text-color); margin-bottom: 28px; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .bgg-hero { height: var(--bgg-height-mobile); padding: 30px 20px 60px; }
    .bgg-nav__tagline { display: none; }
    .bgg-nav { padding: 0 16px; }
  }
  @media (max-width: 480px) {
    .bgg-btn { font-size: 11px; padding: 10px 16px; }
    .bgg-nav__logo-text { font-size: 15px; }
  }
{%- endstyle -%}

<section class="bgg-section" id="bgg-{{ section.id }}">
  <!-- Nav Bar -->
  <nav class="bgg-nav">
    <a class="bgg-nav__logo-link" href="{{ routes.root_url }}">
      {% if section.settings.logo_image != blank %}
        <img class="bgg-nav__logo-img" src="{{ section.settings.logo_image | img_url: 'master' }}" alt="{{ section.settings.logo_image.alt | default: shop.name }}" style="width: {{ section.settings.logo_width }}px;">
      {% else %}
        <span class="bgg-nav__logo-text">{{ section.settings.logo_text }}</span>
      {% endif %}
    </a>
    <p class="bgg-nav__tagline">{{ section.settings.nav_tagline }}</p>
    <a class="bgg-btn bgg-btn--nav" href="{{ section.settings.cta_choose_url }}">
      <span>{{ section.settings.cta_choose_label }}</span>
      <svg class="bgg-btn__arrow" viewBox="0 0 18 12"><path d="M0 6h16M11 1l5 5-5 5"/></svg>
    </a>
  </nav>

  <!-- Hero Section -->
  <div class="bgg-hero">
    <div class="bgg-hero__bg-wrap">
      {% if section.settings.bg_image_desktop != blank %}
        <picture>
          {% if section.settings.bg_image_mobile != blank %}
            <source media="(max-width: 768px)" srcset="{{ section.settings.bg_image_mobile | img_url: '800x' }}">
          {% endif %}
          <img class="bgg-hero__bg-img" src="{{ section.settings.bg_image_desktop | img_url: '1600x' }}" alt="Banner background">
        </picture>
      {% else %}
        <div style="width:100%; height:100%; background:#ddd;"></div>
      {% endif %}
      <div class="bgg-hero__overlay"></div>
    </div>

    <div class="bgg-hero__content">
      <h1 class="bgg-hero__heading">{{ section.settings.heading }}</h1>
      <p class="bgg-hero__description">{{ section.settings.description }}</p>
      <a class="bgg-btn bgg-btn--hero" href="{{ section.settings.cta_shop_url }}">
        <span>{{ section.settings.cta_shop_label }}</span>
        <svg class="bgg-btn__arrow" viewBox="0 0 18 12"><path d="M0 6h16M11 1l5 5-5 5"/></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner – Gift Guide",
  "settings": [
    { "type": "header", "content": "Navigation Settings" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo Image (Optional)" },
    { "type": "range", "id": "logo_width", "min": 50, "max": 250, "step": 5, "unit": "px", "label": "Logo Width", "default": 120 },
    { "type": "text", "id": "logo_text", "label": "Logo Text Fallback", "default": "TISSO VISON" },
    { "type": "text", "id": "nav_tagline", "label": "Tagline", "default": "Find the ideal gift for your loved ones." },
    { "type": "color", "id": "nav_bg_color", "label": "Nav Background", "default": "#f5f5f0" },
    { "type": "color", "id": "nav_text_color", "label": "Nav Text Color", "default": "#111111" },
    { "type": "text", "id": "cta_choose_label", "label": "Nav Button Text", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "cta_choose_url", "label": "Nav Button Link" },
    { "type": "color", "id": "nav_btn_bg_color", "label": "Nav Button BG", "default": "#f5e130" },
    { "type": "color", "id": "nav_btn_text_color", "label": "Nav Button Text Color", "default": "#111111" },

    { "type": "header", "content": "Hero Images & Layout" },
    { "type": "image_picker", "id": "bg_image_desktop", "label": "Desktop Background" },
    { "type": "image_picker", "id": "bg_image_mobile", "label": "Mobile Background (Optional)" },
    { "type": "range", "id": "height_desktop", "min": 400, "max": 800, "step": 10, "unit": "px", "label": "Desktop Height", "default": 600 },
    { "type": "range", "id": "height_mobile", "min": 300, "max": 700, "step": 10, "unit": "px", "label": "Mobile Height", "default": 500 },
    { "type": "color", "id": "overlay_color", "label": "Overlay Color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "Overlay Opacity", "default": 20 },

    { "type": "header", "content": "Hero Text & Colors" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#ffffff" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Discover Joy: Your Ultimate Holiday Gift Destination." },
    { "type": "color", "id": "text_color", "label": "Description Color", "default": "#ffffff" },

    { "type": "header", "content": "Hero Button Settings" },
    { "type": "text", "id": "cta_shop_label", "label": "Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "cta_shop_url", "label": "Button Link" },
    { "type": "color", "id": "btn_bg_color", "label": "Button Background", "default": "#111111" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text", "default": "#ffffff" },
    { "type": "color", "id": "btn_hover_bg_color", "label": "Hover Background", "default": "#f5e130" },
    { "type": "color", "id": "btn_hover_text_color", "label": "Hover Text Color", "default": "#111111" }
  ],
  "presets": [{ "name": "Banner – Gift Guide" }]
}
{% endschema %}